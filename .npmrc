# .npmrc — ILMORA Education Platform
# Suppress transitive deprecation warnings from Next.js/ESLint internals
# These come from next@14 → eslint-config-next → glob@7, rimraf@2 etc.
# They are NOT our direct dependencies and do NOT affect the build.

fund=false
audit=false
loglevel=error
prefer-dedupe=true
legacy-peer-deps=false
engine-strict=false
